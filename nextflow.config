manifest {
    name            = 'cemselb/nf-singlecell-biomarker'
    author          = 'Cemsel B Suomi'
    homePage        = 'https://github.com/cemselb/nf-singlecell-biomarker'
    description     = 'A Nextflow pipeline for scRNA-seq QC, filtering, and dimensionality reduction.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '1.0.0'
}

params {
    backend    = 'scanpy'
    input_url  = 'https://cf.10xgenomics.com/samples/cell-exp/1.1.0/pbmc3k/pbmc3k_filtered_gene_bc_matrices.tar.gz'
    outdir     = './results'
    min_genes  = 200
    min_cells  = 3
    max_mito   = 5.0
}

process {
    cpus   = 2
    memory = 6.GB
    time   = 1.h

    withName: 'RUN_DIMRED|FIND_BIOMARKERS|ANNOTATE_CELLS|SCORE_SIGNATURES' {
        cpus   = 4
        memory = 12.GB
    }
}

profiles {
    conda {
        process.conda = "${projectDir}/environment.yml"
    }
    docker {
        docker.enabled       = true
        docker.userEmulation = true
        process.container    = 'continuumio/miniconda3:latest' 
    }
    test {
        process {
            cpus   = 2
            memory = 6.GB
            time   = 1.h
        }
    }
}
