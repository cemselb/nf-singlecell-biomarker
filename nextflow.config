// nextflow.config
manifest {
    name            = 'cemselb/nf-singlecell-biomarker'
    author          = 'Cemsel B Suomi'
    homePage        = 'https://github.com/cemselb/nf-singlecell-biomarker'
    description     = 'A Nextflow pipeline for scRNA-seq QC, filtering, and dimensionality reduction.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '1.0.0'
}

params.backend = 'scanpy'
params.input_url  = 'https://cf.10xgenomics.com/samples/cell-exp/1.1.0/pbmc3k/pbmc3k_filtered_gene_bc_matrices.tar.gz'
params.outdir     = './results'
params.min_genes  = 200
params.min_cells  = 3
params.max_mito   = 5.0

profiles {
    docker {
        docker.enabled = true
    }
}

process {
    container = { params.backend == 'seurat' ? 'satijalab/seurat:4.3.0' : 'quay.io/biocontainers/scanpy:1.9.3--pyhdfd78af_0' }
    withName: 'RUN_MULTIQC' {
        container = 'quay.io/biocontainers/multiqc:1.14--pyhdfd78af_0'
    }
}
